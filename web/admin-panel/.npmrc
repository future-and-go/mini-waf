# legacy-peer-deps=true silences a transitive peer-dep conflict that cannot
# be fixed upstream:
#
#   kbar@0.1.0-beta.48 (latest) still pins react-virtual@^2.8.2
#   react-virtual@2.10.4 (latest of v2 line, unmaintained) declares
#     peerDependencies: { react: '^16.6.3 || ^17.0.0' }
#
# The package works fine at runtime under React 18 (only uses hooks that
# exist in both 17 and 18), but the metadata mismatch causes npm to emit
# ERESOLVE warnings on every install. Upstream kbar has moved to
# @tanstack/react-virtual only in unreleased main; until a new kbar release
# ships, we fall back to npm-6-era peer resolution to keep installs quiet.
legacy-peer-deps=true
