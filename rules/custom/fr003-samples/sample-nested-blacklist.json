{
  "_comment": "FR-003 AC-8 — nested AND/OR/Not. Blocks (suspicious IP CIDR OR known-bad session cookie) AND request hits an admin path. Demonstrates match_tree taking precedence over flat conditions.",
  "host_code": "*",
  "name": "Nested admin blacklist: bad-source AND admin-path",
  "priority": 10,
  "enabled": true,
  "condition_op": "and",
  "conditions": [],
  "match_tree": {
    "and": [
      {
        "or": [
          { "field": "ip", "operator": "cidr_match", "value": "10.0.0.0/8" },
          { "field": { "cookie": "session" }, "operator": "eq", "value": "bad" }
        ]
      },
      {
        "not": {
          "field": "method",
          "operator": "eq",
          "value": "OPTIONS"
        }
      },
      { "field": "path", "operator": "wildcard", "value": "/api/*/admin" }
    ]
  },
  "action": "block",
  "action_status": 403,
  "action_msg": "Forbidden"
}
